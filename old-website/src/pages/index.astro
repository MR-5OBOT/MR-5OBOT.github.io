---
import Base from '../layouts/Base.astro';
import SketchFrame from '../components/SketchFrame.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Add / edit projects here — the grid renders itself.
const projects = [
  { title: 'TJ_Analyser', desc: 'Trade journal that grades my mistakes &mdash; in color, so it hurts more.' },
  { title: 'TJ_Analyser Mobile', desc: 'Same regret, now pocket-sized. Still very much a work in progress.' },
  { title: 'CLI Toolbox', desc: "Scripts that automate the losing. At least it's fast now." },
  { title: 'This Site', desc: "You're looking at it. Peak over-engineering of a three-page portfolio." },
];
---
<Base title="hover demo — steal these">
  <div class="hero">
    <div>
      <h1><span data-decode>Are you</span><br><span data-decode>1 or 0?</span></h1>
      <p class="sub">fsociety traders. exit the matrix, enter the drawdown.</p>
    </div>

    <div class="frame">
      <SketchFrame />
      <div class="photo-wrap"><img class="photo" src="/assets/logo3.jpg" alt=""></div>

      <!-- lightbulb (inline SVG, no asset needed) -->
      <svg class="reveal bulb" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50" fill="#e7e7ee" aria-hidden="true">
        <path d="M28.374,14.593c0,1.883-1.636,3.157-3.518,3.157c-1.883,0-3.229-1.419-3.229-3.301s1.59-3.307,3.639-3.253S28.374,12.71,28.374,14.593z"></path>
        <path d="M24.855,18.25c-2.126,0-3.729-1.634-3.729-3.802c0-0.996,0.391-1.925,1.102-2.616c0.784-0.764,1.854-1.161,3.051-1.137c2.185,0.058,3.596,1.588,3.596,3.898C28.874,16.643,27.108,18.25,24.855,18.25z M25.15,11.693c-0.87,0-1.657,0.301-2.226,0.854c-0.515,0.502-0.799,1.176-0.799,1.9c0,1.624,1.147,2.802,2.729,2.802c1.721,0,3.019-1.142,3.019-2.657c0-1.771-0.98-2.854-2.623-2.898C25.218,11.694,25.185,11.693,25.15,11.693z"></path>
        <path d="M25.432,46.979c-0.398,0-0.799-0.01-1.201-0.029C11.947,46.352,3.217,37.306,3,24.952c-0.097-5.506,2.685-11.812,7.085-16.064c2.905-2.807,7.877-6.069,15.154-5.696C37.094,3.809,46.855,13.564,47,24.937c0.08,6.292-2.238,12.035-6.526,16.172C36.524,44.918,31.221,46.979,25.432,46.979z M24.099,4.162c-6.315,0-10.703,2.918-13.318,5.445C6.569,13.676,3.907,19.692,4,24.935c0.207,11.802,8.547,20.445,20.279,21.017c5.966,0.294,11.479-1.684,15.5-5.562c4.088-3.944,6.297-9.427,6.221-15.439C45.862,14.094,36.525,4.781,25.187,4.191C24.818,4.171,24.455,4.162,24.099,4.162z"></path>
        <path d="M27.53,39.218c-1.642,0.374-3.237,0.377-4.778-0.072c-0.124-5.087-0.146-10.606-0.011-17.285c1.671-0.197,3.398-0.421,4.789-0.184C27.84,28.378,27.799,34.111,27.53,39.218z"></path>
        <path d="M25.206,39.989c-0.896,0-1.762-0.121-2.594-0.363c-0.209-0.061-0.354-0.25-0.36-0.468c-0.135-5.533-0.138-11.032-0.011-17.307c0.005-0.25,0.193-0.457,0.441-0.486l0.235-0.028c1.623-0.192,3.302-0.39,4.695-0.152c0.231,0.039,0.404,0.235,0.415,0.469c0.293,6.292,0.293,12.045,0,17.59c-0.012,0.223-0.17,0.412-0.388,0.461C26.811,39.895,25.997,39.989,25.206,39.989z M27.529,39.218h0.01H27.529z M23.243,38.759c1.194,0.29,2.474,0.306,3.807,0.048c0.265-5.27,0.265-10.739-0.001-16.69c-1.131-0.116-2.487,0.034-3.816,0.19C23.117,28.246,23.12,33.496,23.243,38.759z"></path>
      </svg>

      <!-- speech cloud: fluffy top+bottom, centered text, outline + shadow + volume -->
      <svg class="reveal cloud" viewBox="0 0 280 185">
        <defs>
          <linearGradient id="cloudfill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#ffffff"/>
            <stop offset="1" stop-color="#e7e7ee"/>
          </linearGradient>
          <filter id="cloudfx" x="-25%" y="-25%" width="150%" height="170%">
            <feMorphology in="SourceAlpha" operator="dilate" radius="2" result="dil"/>
            <feFlood flood-color="#141414" result="ink"/>
            <feComposite in="ink" in2="dil" operator="in" result="outline"/>
            <feMerge>
              <feMergeNode in="outline"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>
        <g fill="url(#cloudfill)" filter="url(#cloudfx)">
          <ellipse cx="140" cy="92" rx="108" ry="46"/>
          <circle cx="80"  cy="58" r="34"/>
          <circle cx="125" cy="48" r="30"/>
          <circle cx="170" cy="48" r="32"/>
          <circle cx="208" cy="60" r="36"/>
          <circle cx="48"  cy="92" r="34"/>
          <circle cx="232" cy="92" r="34"/>
          <circle cx="80"  cy="124" r="32"/>
          <circle cx="128" cy="134" r="30"/>
          <circle cx="176" cy="134" r="30"/>
          <circle cx="212" cy="124" r="32"/>
          <circle cx="44"  cy="156" r="13"/>
          <circle cx="24"  cy="174" r="8"/>
        </g>
        <g text-anchor="middle" fill="#141414" font-family="Space Grotesk" font-weight="700" font-size="17" letter-spacing=".3">
          <text x="140" y="82">just a</text>
          <text x="140" y="101">simulations pro</text>
          <text x="140" y="120">nothing real</text>
        </g>
      </svg>

      <div class="tag">MR5OBOT</div>
    </div>
  </div>

  <section id="works">
    <h2 class="works-title reveal-up" data-decode>My Projects</h2>
    <div class="cards">
      {projects.map((p) => <ProjectCard title={p.title} desc={p.desc} />)}
    </div>
  </section>
</Base>
