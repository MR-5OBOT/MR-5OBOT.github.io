---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string; // shown in Google results + link-preview cards; pages can override
  active?: string;
  transparentNav?: boolean;
  vig?: number; // heatmap centre floor: 0.2 dark home, 0.4 lighter inner pages
  bodyClass?: string;
}
const {
  title = 'MR5OBOT',
  description = 'OHLC trader and token burner. Trading tools, automation experiments, and honest logs of losing money.',
  active = '',
  transparentNav = false,
  vig = 0.2,
  bodyClass = '',
} = Astro.props;
// Social scrapers need absolute URLs, not /paths.
const ogImage = new URL('/assets/profile-2.png', Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/profile-2.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Merienda:wght@700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class={bodyClass} data-vig={vig}>
    <canvas id="bg" transition:persist></canvas>

    <!-- Pixelate filter: sample 1 dot per cell, dilate into blocks, soften -->
    <svg width="0" height="0" style="position:absolute">
      <filter id="pixelate" x="0" y="0" width="100%" height="100%">
        <feFlood x="1" y="1" width="1" height="1" />
        <feComposite width="2" height="2" />
        <feTile result="grid" />
        <feComposite in="SourceGraphic" in2="grid" operator="in" />
        <feMorphology operator="dilate" radius="0.7" />
        <feGaussianBlur stdDeviation="0.5" />
      </filter>
    </svg>

    <Nav active={active} transparent={transparentNav} />

    <slot />

    <Footer />

    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: #9a9a9a;
        font-family: "Space Grotesk", "Helvetica Neue", Arial, sans-serif;
      }
      #bg { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; opacity: .17; }
    </style>

    <script>
      // Pixel-heatmap background — grey grid on black, mirrored, vignette. Shared by all pages.
      // Persisted across View-Transitions nav (transition:persist) so it never redraws/flashes on switch.
      const cv = document.getElementById('bg') as HTMLCanvasElement;
      const ctx = cv.getContext('2d')!;
      const CELL = 96, MAX = 90, GAP = 0;
      const vigOf = () => parseFloat(document.body.dataset.vig || '0.2'); // body swaps on nav -> per-page vig
      let cols = 0, rows = 0, phase = 0, grain = new Float32Array(0);

      function resize() {
        const dpr = Math.min(devicePixelRatio || 1, 2);
        cv.width = innerWidth * dpr; cv.height = innerHeight * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        cols = Math.ceil(innerWidth / CELL); rows = Math.ceil(innerHeight / CELL);
        scramble();
      }

      function scramble() {                                   // fresh grain + wave phase -> the grid visibly reshuffles
        phase = Math.random() * 12;
        grain = Float32Array.from({ length: cols * rows }, () => (Math.random() - 0.5) * 0.7);
        draw();
      }

      function draw() {
        const floor = vigOf();
        const cx = (cols - 1) / 2, cy = (rows - 1) / 2, maxd = Math.hypot(cx, cy);
        for (let y = 0; y < rows; y++) for (let x = 0; x < cols; x++) {
          const xf = Math.min(x, cols - 1 - x);
          const n = Math.sin((xf + phase) * 0.4) + Math.sin((y + phase) * 0.35) + Math.sin((xf + y + phase) * 0.3) + Math.sin((xf - y + phase) * 0.32);
          let v = 0.45 + grain[y * cols + xf] + (n / 4) * 0.25;
          v = Math.max(0, Math.min(1, v));
          const vig = floor + (1 - floor) * (Math.hypot(x - cx, y - cy) / maxd);
          const g = (v ** 1.3 * MAX * vig) | 0;
          ctx.fillStyle = `rgb(${g},${g},${g})`;
          ctx.fillRect(x * CELL, y * CELL, CELL - GAP, CELL - GAP);
        }
      }

      addEventListener('resize', resize);
      resize();

      /* --- page transition: the heatmap rises to full cover, scrambles, recedes over the new page.
             Canvas-only (a few hundred rects for a handful of frames) -> cheap on low-end devices. --- */
      const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
      let burst: any = 0;
      function scrambleBurst(ms: number) {                    // reshuffle a few times while covered
        clearInterval(burst);
        burst = setInterval(scramble, 110);
        setTimeout(() => clearInterval(burst), ms);
      }
      function raise() {
        cv.style.zIndex = '100';                              // over nav/footer -> full cover
        cv.style.opacity = '1';
        scrambleBurst(340);
        return cv.animate([{ opacity: 0.17 }, { opacity: 1 }], { duration: 340, easing: 'ease-in' }).finished;
      }
      function lower() {
        scramble();                                           // the "reassemble" beat, already using the new page's vig
        cv.style.opacity = '';                                // back to the resting CSS opacity
        return cv.animate([{ opacity: 1 }, { opacity: 0.17 }], { duration: 420, easing: 'ease-out' })
          .finished.then(() => { cv.style.zIndex = ''; });
      }
      document.addEventListener('astro:before-preparation', (e: any) => {
        if (reduce) return;
        const orig = e.loader;
        e.loader = async () => { await raise(); await orig(); };  // curtain up first, swap happens under it
      });
      document.addEventListener('astro:after-swap', () => {
        if (cv.style.zIndex === '100') lower();               // new DOM in -> uncover
        else draw();                                          // reduced-motion / history nav: just repaint with new vig
      });
    </script>
  </body>
</html>
