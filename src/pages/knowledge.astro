---
import Base from '../layouts/Base.astro';
import Carousel, { type CarouselItem } from '../components/Carousel.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();

const items: CarouselItem[] = posts.map((post, i) => ({
  label: `// LEAK ${String(i + 1).padStart(2, '0')}`,
  title: post.data.title,
  meta: `${fmt(post.data.date)} · ${post.data.read} · ${post.data.tag}`,
  body: post.data.description,
  cta: post.data.cta,
  href: `/posts/${post.id}`,
}));
---

<Base title="MR5OBOT // Knowledge" active="knowledge" transparentNav vig={0.4} bodyClass="knowledge">
  <Carousel items={items} />

  <style is:global>
    html, body { height: 100%; overflow: hidden; }   /* transform carousel, no native scroll */
    body.knowledge {
      background: #000 radial-gradient(ellipse 700px 320px at 50% 45%, rgba(177,140,255,.07), transparent 70%) fixed;
    }
  </style>
</Base>
