---
// Shared infinite two-up card carousel used by Knowledge (posts) and Jankyard (projects).
export interface CarouselItem {
  title: string;
  meta: string;    // mono sub-line
  body: string;
  cta: string;     // cta text (arrow appended)
  href: string;
  external?: boolean;
}
interface Props {
  items: CarouselItem[];
  big?: boolean;       // larger cards (Jankyard)
  vertical?: boolean;  // same infinite carousel, axis flipped to vertical (Jankyard)
}
const { items, big = false, vertical = false } = Astro.props;
---

<div class:list={['scrollbar', { v: vertical }]}><canvas class="nav-thumb"></canvas></div>

<main class:list={['feed', { big, vertical }]}>
  {items.map((it) => (
    <article class="gem">
      <header><h2>{it.title}</h2><span class="arr">↗</span></header>
      <p class="meta">{it.meta}</p>
      <p class="body">{it.body}</p>
      <hr />
      <a
        class="cta"
        href={it.href}
        target={it.external ? '_blank' : undefined}
        rel={it.external ? 'noopener noreferrer' : undefined}
      >{it.cta} →</a>
    </article>
  ))}
</main>

<style is:global>
  /* horizontal scroll-position line, near the bottom just above the social footer */
  .scrollbar {
    position: fixed; bottom: 90px; left: 20px; right: 20px;
    max-width: 720px; margin: 0 auto; height: 20px; z-index: 49; pointer-events: none;
  }
  .scrollbar::before {                                   /* faint full-width track */
    content: ""; position: absolute; left: 0; right: 0; top: 50%;
    height: 2px; transform: translateY(-50%); background: rgba(255,255,255,.06);
  }
  .nav-thumb {                                           /* bright big-pixel purple bar, slides along the track (starts centred) */
    position: absolute; top: 50%; left: 0; width: 150px; height: 16px;
    transform: translateY(-50%);
    display: block; filter: blur(1.5px) drop-shadow(0 0 8px rgba(58,31,112,.45));
  }

  /* vertical variant (Jankyard): same pixel bar, stood up on the right edge */
  .scrollbar.v { top: 120px; bottom: 120px; left: auto; right: 14px; width: 20px; height: auto; max-width: none; margin: 0; }
  .scrollbar.v::before { left: 50%; right: auto; top: 0; bottom: 0; width: 2px; height: auto; transform: translateX(-50%); }
  .scrollbar.v .nav-thumb { top: 0; left: 50%; width: 16px; height: 150px; transform: translateX(-50%); }

  /* the feed */
  .feed { position: absolute; top: 50%; left: 0; display: flex; align-items: center; z-index: 1; will-change: transform; cursor: grab; user-select: none; }
  .feed.dragging { cursor: grabbing; }
  .feed.vertical { top: 0; left: 50%; flex-direction: column; }   /* stand the same carousel up: translate on Y instead of X */
  .feed.vertical .slide { gap: 40px; }            /* two cards side by side inside each vertical row */
  .feed.vertical .gem { margin: 0; }              /* don't let auto-margins shove the pair apart */
  .slide { flex: 0 0 auto; display: flex; align-items: center; justify-content: center; box-sizing: border-box; will-change: transform, opacity; }

  /* one gem — hand-drawn frame (Framer template asset), 9-sliced so the line stays even on any card size */
  .gem {
    position: relative;
    width: min(620px, 92vw); margin: 0 auto;
    background: #000;
    background-clip: padding-box;                          /* keep the black inside the frame, not bleeding past the line */
    border: 22px solid transparent;
    border-image: url(/knowledge-frame.svg) 40 stretch;
    padding: 10px 16px 8px;
    filter: drop-shadow(-5px 7px 4px rgba(140,140,140,.35)); /* soft offset shadow, no wobbly tick artifacts */
    transition: transform .3s cubic-bezier(.2,.7,.3,1), filter .3s ease;
  }
  .feed.big .gem { padding: 16px 24px 14px; }              /* roomier bigger cards (Jankyard) */
  .gem header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
  .gem .arr  { flex: none; color: #ededed; font-size: 20px; margin-top: 4px; }
  .gem h2 { margin: 0 0 6px; flex: 1; font-size: 32px; font-weight: 700; letter-spacing: -1px; color: #f5f5f5; line-height: 1.1; }
  .feed.big .gem h2 { font-size: 38px; }
  .gem .meta { font-family: "Space Mono", monospace; margin: 0; font-size: 13px; letter-spacing: 1.5px; color: #888; }
  .gem .body { margin: 22px 0 0; font-size: 16px; line-height: 1.6; color: #9a9a9a; }
  .feed.big .gem .body { font-size: 17px; }
  .gem hr { border: 0; border-top: 1px solid #2a2a2a; margin: 22px 0 16px; }
  .gem .cta { font-family: "Space Mono", monospace; font-size: 14px; letter-spacing: 1px; color: #ededed; text-decoration: none; }
  .gem .cta:hover { filter: url(#pixelate); }
  /* casual placement: tilt each card a hair so the row isn't dead-straight */
  .slide:nth-child(odd)  .gem { transform: rotate(-1.4deg); }
  .slide:nth-child(even) .gem { transform: rotate(1.2deg); }
  /* hover: straighten, lift, deepen the shadow */
  .slide:hover .gem { transform: translateY(-8px) rotate(0deg) scale(1.02); filter: drop-shadow(-5px 8px 5px rgba(140,140,140,.3)); }
</style>

<script>
  /* Infinite gallery: active card(s) centered, dim neighbors peeking. Horizontal two-up by default;
     Jankyard flips the axis to vertical via the `vertical` class (same math, X<->Y), two cards per row.
     Wheel/key/swipe accumulates into an integer target; cur eases toward it each frame and
     wraps a whole set (per) mid-glide -> infinite + seamless. */
  (() => {
    const feed = document.querySelector('.feed');
    if (!feed) return;
    const thumb = document.querySelector('.nav-thumb'), tctx = thumb.getContext('2d');
    const V = feed.classList.contains('vertical');            // axis flip: Jankyard stands the carousel up
    const bigCards = feed.classList.contains('big');
    const base = [...feed.children];
    feed.replaceChildren();
    // a "unit" gets its own slide: one card horizontally, a row of two cards vertically
    const groups = [];
    if (V) for (let i = 0; i < base.length; i += 2) groups.push(base.slice(i, i + 2));
    else   base.forEach(g => groups.push([g]));
    const mk = gems => { const s = document.createElement('div'); s.className = 'slide'; gems.forEach(g => s.appendChild(g)); return s; };
    for (let c = 0; c < 3; c++) groups.forEach(gm => feed.appendChild(mk(c ? gm.map(g => g.cloneNode(true)) : gm)));
    const slides = [...feed.children], cards = slides.map(s => s.firstElementChild), per = groups.length;
    const everyCard = slides.flatMap(s => [...s.children]);

    function pix() {                                          // bright big-pixel purple bar, soft only at the ends -> a straight line
      const w = thumb.width, h = thumb.height, C = 6;
      tctx.clearRect(0, 0, w, h);
      tctx.fillStyle = '#3a1f72';
      for (let y = 0; y < h; y += C) for (let x = 0; x < w; x += C) {
        const along = V ? y / h : x / w, across = V ? x / w : y / h;
        const fa = Math.min(1, (1 - Math.abs(along - 0.5) * 2) * 2.5);  // full across, taper the two ends
        const fb = 0.6 + 0.4 * (1 - Math.abs(across - 0.5) * 2);        // gentle side fade
        tctx.globalAlpha = (0.55 + Math.random() * 0.35) * fa * fb;
        tctx.fillRect(x, y, C - 1, C - 1);
      }
    }
    function sizeThumb() { const r = thumb.getBoundingClientRect(); thumb.width = Math.max(1, r.width | 0); thumb.height = Math.max(1, r.height | 0); pix(); }

    const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
    let cur = per, target = per, size = 0, pair = 1, raf = 0;

    function layout() {
      sizeThumb();
      if (V) {                                                // vertical: each row holds two cards; rows peek above/below
        pair = 0;                                             // one row centred
        slides.forEach(s => { s.style.height = ''; s.style.width = ''; });
        everyCard.forEach(g => g.style.width = Math.min(bigCards ? 500 : 460, (innerWidth - 120) / 2) + 'px');
        size = Math.max(...slides.map(s => s.offsetHeight)) + 28;   // stride = row height + gap
        slides.forEach(s => s.style.height = size + 'px');
      } else {
        pair = innerWidth >= 760 ? 1 : 0;                     // two-up on desktop, one-up on phones
        size = pair
          ? Math.min(bigCards ? 700 : 560, innerWidth * (bigCards ? 0.48 : 0.46))
          : Math.min(bigCards ? 720 : 560, innerWidth - 40);
        slides.forEach(s => { s.style.width = size + 'px'; s.style.height = ''; });
        cards.forEach(g => g.style.width = (size - 40) + 'px'); // 40px gutter between cards
      }
      render();
    }
    function render() {
      const mid = (cur + 0.5 + 0.5 * pair) * size;            // straddle the gap (two-up) or center the card
      feed.style.transform = V
        ? `translate(-50%, ${innerHeight / 2 - mid}px)`
        : `translate(${innerWidth / 2 - mid}px, -50%)`;
      const aD = 0.5 * pair;
      for (let i = 0; i < cards.length; i++) {
        const k = Math.max(0, Math.abs(i - (cur + aD)) - aD); // 0 for the active card(s), grows outward
        const op = Math.max(0, 1 - k * 0.5);
        slides[i].style.transform = `scale(${1 - k * 0.12})`; // scale the wrapper, not .gem, so the frame stays put
        slides[i].style.opacity = op;
        slides[i].inert = op < 0.5;                           // off-screen clones drop out of tab order + a11y tree
      }
      const f = (((cur % per) + per) % per) / per;            // 0..1 position within the set
      const fc = (f + 0.5) % 1;                                // start centred, then scroll moves it from the middle
      const rail = thumb.parentElement;
      if (V) thumb.style.top = fc * (rail.clientHeight - thumb.offsetHeight) + 'px';
      else   thumb.style.left = fc * (rail.clientWidth - thumb.offsetWidth) + 'px';
    }
    function tick() {
      cur += (target - cur) / (reduce ? 1 : 6);
      if (cur < per)            { cur += per; target += per; }    // seamless wrap mid-glide
      else if (cur >= 2 * per)  { cur -= per; target -= per; }
      if (Math.abs(target - cur) < 0.001) { cur = target; render(); raf = 0; return; }
      render(); raf = requestAnimationFrame(tick);
    }
    const MAX = 4;                                             // cap look-ahead so a fling never runs away
    function step(n) {
      target += n;
      if (target - cur > MAX) target = Math.ceil(cur) + MAX;
      else if (cur - target > MAX) target = Math.floor(cur) - MAX;
      if (!raf) raf = requestAnimationFrame(tick);
    }

    let acc = 0;
    addEventListener('wheel', e => {
      e.preventDefault();
      const d = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;  // vertical wheel or sideways trackpad
      acc += d * (e.deltaMode === 1 ? 16 : 1);                // normalise line-mode wheels to px
      const n = acc / 100 | 0;                                // ~100px per card
      if (n) { acc -= n * 100; step(n); }
    }, { passive: false });

    addEventListener('keydown', e => {
      if (['ArrowDown', 'ArrowRight', 'PageDown', ' '].includes(e.key)) { e.preventDefault(); step(1); }
      else if (['ArrowUp', 'ArrowLeft', 'PageUp'].includes(e.key))      { e.preventDefault(); step(-1); }
    });

    let tp = 0;
    const tpos = t => V ? t.clientY : t.clientX;
    addEventListener('touchstart', e => tp = tpos(e.touches[0]), { passive: true });
    addEventListener('touchend',  e => { const d = tp - tpos(e.changedTouches[0]); if (Math.abs(d) > 40) step(Math.sign(d)); }, { passive: true });

    /* click-and-drag to scroll (mouse/pen; touch already swipes above) */
    let dragging = false, dragPrev = 0;
    addEventListener('pointerdown', e => {
      if (e.pointerType === 'touch' || e.button || e.target.closest('a')) return;  // left-drag only, let links click
      dragging = true; dragPrev = V ? e.clientY : e.clientX;
      feed.classList.add('dragging');
    });
    addEventListener('pointermove', e => {
      if (!dragging) return;
      const p = V ? e.clientY : e.clientX;
      target -= (p - dragPrev) / size;                       // 1 card per stride, follows the pointer
      dragPrev = p; cur = target;
      if (cur < per)           { cur += per; target += per; } // same seamless wrap as tick()
      else if (cur >= 2 * per) { cur -= per; target -= per; }
      render();
    });
    function endDrag() { if (!dragging) return; dragging = false; feed.classList.remove('dragging'); step(Math.round(target) - target); }
    addEventListener('pointerup', endDrag);
    addEventListener('pointercancel', endDrag);

    addEventListener('resize', layout);
    layout();
    if (document.fonts) document.fonts.ready.then(layout);
  })();
</script>
