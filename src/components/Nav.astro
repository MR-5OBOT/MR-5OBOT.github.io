---
interface Props {
  active?: string;
  transparent?: boolean;
}
const { active = '', transparent = false } = Astro.props;
const links = [
  { href: '/jankyard', key: 'jankyard', label: 'Jankyard' },
  { href: '/knowledge', key: 'knowledge', label: 'Knowledge' },
];
---
<nav class:list={['nav', { transparent }]}>
  <a class="logo" href="/">
    <span class="logo-name">MR5OBOT</span>
  </a>
  {links.map((l) => <a href={l.href} class:list={{ active: active === l.key }}>{l.label}</a>)}
</nav>

<style>
  /* Navbar wearing the same hand-drawn frame as the cards, on a #101010 fill */
  .nav {
    position: fixed; top: 24px; left: 20px; right: 20px;
    max-width: 720px; margin: 0 auto; z-index: 50;
    background: transparent;                                /* fill is baked into the frame SVG, clipped to the drawn line */
    border: 18px solid transparent;
    border-image: url(/nav-frame.svg) 40 fill stretch;
    padding: 4px 18px;
    display: flex; align-items: center; gap: 32px;
  }
  .nav .logo { margin-right: auto; text-decoration: none; }
  .nav .logo:hover .logo-name { color: #a280ea; filter: url(#pixelate); }  /* pixel-burst the wordmark */
  .logo-name { font-family: 'Merienda', cursive; letter-spacing: .15em; font-size: 20px; color: #fff; }
  .nav a { color: #ddd; text-decoration: none; font-weight: 500; font-size: 20px; transition: color .2s; }
  .nav a:hover { color: #a280ea; filter: url(#pixelate); }   /* text breaks into soft pixels */
  .nav a.active { color: #b18cff; }
  @media (max-width: 560px) {
    .nav { top: 12px; left: 12px; right: 12px; gap: 18px; padding: 2px 10px; }
    .nav a, .logo-name { font-size: 16px; }
  }
</style>
